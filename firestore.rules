rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Admin Only
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Staff or Admin
    function isStaff() {
       return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff');
    }

    // Helper: Owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Products - public read, admin/staff write (staff with permission, handled in app, for rules just Admin/Staff)
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    // Services - same
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    // Articles - same
    match /articles/{articleId} {
      allow read: if true;
      allow write: if isStaff();
    }
    
    // System Config - public read, admin only write
    match /system_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories & Brands - public read (storefront filtering), admin write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    // Services - public read (storefront), admin write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics Dashboard
    match /analytics/{dateStr} {
      allow read: if true;
      allow write: if false; // All writes must now go through secure Admin SDK API
      
      // Protect the subcollection as well
      match /visits/{deviceId} {
        allow read, write: if false;
      }
    }

    // Users
    match /users/{userId} {
      // Read: owner reads own, staff/admin reads all
      allow read: if isOwner(userId) || isStaff();

      // Create: owner creates own (signup), OR admin creates for others (e.g. promoting)
      allow create: if isOwner(userId) || isAdmin();

      // Update: owner updates own profile, OR admin updates any (for role/permission management)
      allow update: if isOwner(userId) || isAdmin();

      // Delete: admin only
      allow delete: if isAdmin();
    }
    
    // Orders
    match /orders/{orderId} {
      // Staff/Admin read all. Public cannot read orders directly.
      allow read: if isStaff();
      // Anyone can create an order (guest checkout & POS) — validated
      allow create: if request.resource.data.keys().hasAll(['customer_info', 'items', 'total_amount', 'status'])
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 50;
      // Staff/Admin update/delete.
      allow update, delete: if isStaff();
    }
    
    // Appointments
    match /appointments/{appointmentId} {
      allow create: if true; // Public can create appointments
      allow read: if true;   // Public for tracking
      allow update, delete: if isStaff();
    }

    // Repairs
    match /repairs/{repairId} {
      allow read: if true; // Public for tracking
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Activities
    match /activities/{activityId} {
      allow read, write: if isStaff();
    }

    // Media Library
    match /media_library/{mediaId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // Subscribers
    match /subscribers/{subscriberId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // --- ERP Mini Modules ---
    
    // Inventory
    match /import_receipts/{receiptId} {
      allow read, write: if isStaff();
    }

    // Commissions
    match /commission_rules/{ruleId} {
      allow read, write: if isStaff();
    }
    match /commissions/{commissionId} {
      allow read, write: if isStaff();
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read, write: if isStaff();
    }

    // Customer Reviews
    match /reviews/{reviewId} {
      allow create: if true; // Public can create
      allow read: if resource.data.status == 'approved' || request.auth != null; // Public reads approved, staff reads all
      allow update, delete: if isStaff(); // Only staff/admin can moderate
    }

    // Article Comments (Bình luận + đánh giá bài viết)
    match /article_comments/{commentId} {
      // Bất kỳ ai (kể cả không đăng nhập) đều có thể gửi và xem bình luận
      allow create, read: if true;

      // Chỉ staff/admin được quyền cập nhật/xoá (moderation, đổi status, ẩn spam...)
      allow update, delete: if isStaff();
    }
  }
}
