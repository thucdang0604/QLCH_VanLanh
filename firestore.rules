rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper: Admin Only
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper: Staff or Admin
    function isStaff() {
       return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff');
    }

    // Helper: Granular Permission Check
    function hasPermission(permission) {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'staff' &&
          'permissions' in get(/databases/$(database)/documents/users/$(request.auth.uid)).data &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.permissions.hasAny([permission])
        )
      );
    }

    function canManageCustomerData() {
      return hasPermission('manage_customers');
    }

    function customerDocMatchesId(data, customerId) {
      return (!('phone' in data) || data.phone == '' || data.phone == customerId)
        || ('customerId' in data && data.customerId == customerId)
        || ('id' in data && data.id == customerId)
        || ('code' in data && data.code == customerId);
    }

    function customerPhoneUpdateAllowed() {
      return !('phone' in resource.data)
        || resource.data.phone == ''
        || (('phone' in request.resource.data) && request.resource.data.phone == resource.data.phone);
    }

    function canViewRevenueSources() {
      return hasPermission('view_revenue');
    }

    function productStockCoversHeld() {
      return (!('stock' in request.resource.data) || request.resource.data.stock is number)
        && (!('held' in request.resource.data) || request.resource.data.held is number)
        && (!('stock' in request.resource.data)
          || !('held' in request.resource.data)
          || request.resource.data.stock >= request.resource.data.held);
    }

    // Helper: Owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Products - public read, catalog maintenance for product and inventory workflows
    match /products/{productId} {
      allow read: if true;
      allow create: if productStockCoversHeld()
        && (hasPermission('manage_products') || hasPermission('manage_inventory')
          || (hasPermission('manage_repairs') && request.resource.data.isProposed == true && request.resource.data.stock == 0));
      allow update: if (hasPermission('manage_products') || hasPermission('manage_inventory'))
        && productStockCoversHeld();
      allow delete: if hasPermission('manage_products') || hasPermission('manage_inventory');
    }

    // Unique product-code claims used by QR, barcode and SKU flows
    match /product_code_registry/{code} {
      allow read: if isStaff();
      allow create: if hasPermission('manage_products') || hasPermission('manage_inventory') || hasPermission('manage_repairs');
      allow update, delete: if hasPermission('manage_products') || hasPermission('manage_inventory');
    }
    
    // Services - same
    match /services/{serviceId} {
      allow read: if true;
      allow write: if hasPermission('manage_services');
    }
    
    // Articles - same
    match /articles/{articleId} {
      allow read: if true;
      allow write: if hasPermission('manage_articles');
    }
    
    // System Config - public read, admin only write
    match /system_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Private server-side configuration. Access only through Admin SDK APIs.
    match /private_config/{docId} {
      allow read, write: if false;
    }

    // Categories & Brands - public read (storefront filtering), admin write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /brands/{brandId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Analytics Dashboard
    match /analytics/{dateStr} {
      allow read: if true;
      allow write: if false; // All writes must now go through secure Admin SDK API
      
      // Protect the subcollection as well
      match /visits/{deviceId} {
        allow read, write: if false;
      }
    }

    // Users
    match /users/{userId} {
      // Helper function to check if the create request has safe default role and permissions
      function isValidUserCreate() {
        return request.resource.data.role == 'customer'
          && !('permissions' in request.resource.data);
      }

      // Helper function to check if only non-sensitive profile fields are modified
      function onlySafeProfileUpdate() {
        return request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(['displayName', 'name', 'phone', 'photoURL', 'updatedAt']);
      }

      // Read: owner reads own, staff/admin reads all
      allow read: if isOwner(userId) || isStaff();

      // Create: owner creates own (signup with customer role), OR admin creates/promotes
      allow create: if (isOwner(userId) && isValidUserCreate()) || isAdmin();

      // Update: owner updates own profile (only safe fields), OR admin updates any
      allow update: if (isOwner(userId) && onlySafeProfileUpdate()) || isAdmin();

      allow delete: if isAdmin();
    }
    
    // Customers
    match /customers/{customerId} {
      allow read: if canManageCustomerData();
      allow create: if canManageCustomerData() && customerDocMatchesId(request.resource.data, customerId);
      allow update: if canManageCustomerData()
        && (customerDocMatchesId(request.resource.data, customerId) || customerDocMatchesId(resource.data, customerId))
        && customerPhoneUpdateAllowed()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['totalSpent', 'totalOrders', 'totalRepairs', 'totalAppointments', 'missions']);
      allow delete: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if hasPermission('manage_orders') || canViewRevenueSources();
      allow create: if false;
      allow update: if hasPermission('manage_orders')
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['status', 'assignedSellerId', 'assignedSellerName', 'assignedSellerAt', 'assignedBy', 'items', 'total_amount', 'subtotal_amount', 'discount_amount', 'shipping_fee', 'voucherCode', 'voucherDiscount']);
      allow delete: if false;
    }
    
    // Appointments
    match /appointments/{appointmentId} {
      allow create: if false;
      allow read: if hasPermission('manage_orders');
      allow update, delete: if hasPermission('manage_orders');
    }

    // Repairs
    match /repairs/{repairId} {
      function canModifyRepairTicket() {
        let hasAssignedKTV = 'staff' in resource.data && 'assignedTechnician' in resource.data.staff && resource.data.staff.assignedTechnician != null;
        let isAssignedKTV = hasAssignedKTV && resource.data.staff.assignedTechnician == request.auth.uid;
        let isUnassigned = !hasAssignedKTV;
        let isManager = isAdmin() || (hasPermission('manage_repairs') && hasPermission('manage_orders'));
        return isAssignedKTV || isUnassigned || isManager;
      }

      allow read: if hasPermission('manage_repairs') || canViewRevenueSources();
      allow create: if false; // Tắt hoàn toàn tạo từ client, bắt buộc qua Server API
      allow update: if hasPermission('manage_repairs')
        && canModifyRepairTicket()
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['parts', 'payment', 'status', 'statusTimeline', 'partsLockedAt', 'pendingTechnicianTransfer', 'staff']);
      allow delete: if isAdmin();
    }

    // Activities
    match /activities/{activityId} {
      allow read, write: if hasPermission('manage_settings');
    }

    // Media Library
    match /media_library/{mediaId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }

    // Subscribers
    match /subscribers/{subscriberId} {
      function isValidPublicSubscriberCreate() {
        return request.resource.data.status == 'active'
          && request.resource.data.subscribedAt == request.time
          && request.resource.data.keys().hasAll(['email', 'subscribedAt', 'status'])
          && request.resource.data.keys().hasOnly(['email', 'subscribedAt', 'status'])
          && request.resource.data.email is string
          && request.resource.data.email.size() >= 5
          && request.resource.data.email.size() <= 254
          && request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$');
      }

      allow create: if isValidPublicSubscriberCreate();
      allow read, update, delete: if isAdmin();
    }

    // --- ERP Mini Modules ---
    
    // Inventory
    match /import_receipts/{receiptId} {
      allow read: if hasPermission('manage_inventory') || canViewRevenueSources();
      allow create: if hasPermission('manage_inventory');
      allow update: if hasPermission('manage_inventory') && resource.data.status != 'completed';
      allow delete: if hasPermission('manage_inventory') && resource.data.status != 'completed';
    }
    match /inventory_logs/{logId} {
      allow read, write: if hasPermission('manage_inventory');
    }
    match /inventory_lots/{lotId} {
      allow read, write: if hasPermission('manage_inventory');
    }

    // Commissions
    match /commission_rules/{ruleId} {
      allow read: if hasPermission('view_commissions');
      allow write: if isAdmin();
    }
    match /commissions/{commissionId} {
      allow read: if hasPermission('view_commissions') || canViewRevenueSources();
      allow write: if isAdmin();
    }
    
    // Server-only Collections
    match /operation_requests/{docId} {
      allow read, write: if false;
    }
    match /customer_ledger/{docId} {
      allow read, write: if false;
    }

    // Expenses
    match /expenses/{expenseId} {
      allow read, write: if hasPermission('view_revenue');
    }
    match /revenue_daily_aggregates/{aggregateId} {
      allow read: if hasPermission('view_revenue');
      allow write: if false;
    }
    match /revenue_monthly_aggregates/{aggregateId} {
      allow read: if hasPermission('view_revenue');
      allow write: if false;
    }

    // Suppliers
    match /suppliers/{supplierId} {
      allow read, write: if hasPermission('manage_inventory');
    }
    match /supplier_transactions/{txnId} {
      allow read, write: if hasPermission('manage_inventory');
    }

    // Accessory Discount Rules
    match /accessory_discount_rules/{ruleId} {
      allow read, write: if hasPermission('manage_settings');
    }

    // Vouchers (Mã giảm giá) — public read để storefront validate mã
    // usedCount chỉ được tăng qua Admin SDK (checkout API server-side)
    match /vouchers/{voucherId} {
      allow read: if hasPermission('manage_discounts');
      allow create, update, delete: if hasPermission('manage_discounts');
    }

    // Customer Reviews — public create ép pending, whitelist fields, validate types
    match /reviews/{reviewId} {
      allow create: if false
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasAll(['customerName', 'phone', 'rating', 'content', 'status', 'createdAt'])
        && request.resource.data.keys().hasOnly(['referenceId', 'type', 'customerName', 'phone', 'rating', 'content', 'images', 'status', 'createdAt', 'verification'])
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() >= 2
        && request.resource.data.customerName.size() <= 100
        && request.resource.data.phone is string
        && request.resource.data.phone.size() >= 4
        && request.resource.data.phone.size() <= 20
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 2000
        && (!('referenceId' in request.resource.data) || request.resource.data.referenceId is string)
        && (!('type' in request.resource.data) || request.resource.data.type in ['general', 'repair'])
        && (!('images' in request.resource.data) || (request.resource.data.images is list && request.resource.data.images.size() <= 5))
        && (!('verification' in request.resource.data) || request.resource.data.verification in ['pin', 'geolocation']);
      allow read: if resource.data.status == 'approved' || hasPermission('manage_reviews');
      allow update, delete: if hasPermission('manage_reviews');
    }

    // Product Reviews — public create ép pending, whitelist fields
    match /product_reviews/{reviewId} {
      allow create: if false
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasAll(['productId', 'customerName', 'rating', 'content', 'status', 'createdAt'])
        && request.resource.data.keys().hasOnly(['productId', 'customerName', 'phone', 'rating', 'content', 'images', 'status', 'createdAt'])
        && request.resource.data.productId is string
        && request.resource.data.customerName is string
        && request.resource.data.customerName.size() >= 2
        && request.resource.data.customerName.size() <= 100
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 2000
        && (!('phone' in request.resource.data) || (request.resource.data.phone is string && request.resource.data.phone.size() <= 20))
        && (!('images' in request.resource.data) || (request.resource.data.images is list && request.resource.data.images.size() <= 5));
      allow read: if resource.data.status == 'approved' || hasPermission('manage_reviews');
      allow update, delete: if hasPermission('manage_reviews');
    }

    // Article Comments — public create ép pending, whitelist fields
    match /article_comments/{commentId} {
      allow create: if false
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && request.resource.data.keys().hasAll(['articleId', 'rating', 'name', 'content', 'status', 'createdAt'])
        && request.resource.data.keys().hasOnly(['articleId', 'rating', 'name', 'phone', 'content', 'status', 'createdAt'])
        && request.resource.data.articleId is string
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 2
        && request.resource.data.name.size() <= 100
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 2000
        && (!('phone' in request.resource.data) || (request.resource.data.phone is string && request.resource.data.phone.size() <= 20));
      allow read: if resource.data.status == 'approved' || hasPermission('manage_articles');
      allow update, delete: if hasPermission('manage_articles');
    }
  }
}
