{
  "rules": {
    "chats": {
      "$roomId": {
        ".read": true,
        ".write": true,
        "info": {
          ".validate": "newData.hasChildren(['displayName']) || newData.hasChildren(['lastMessage']) || newData.hasChildren(['botActive']) || newData.hasChildren(['hasUnread'])"
        },
        "messages": {
          "$messageId": {
            ".validate": "newData.hasChildren(['text', 'senderId', 'senderType', 'timestamp'])"
          }
        }
      },
      ".read": "auth != null"
    },
    "online_users": {
      ".read": "auth != null",
      "$sessionId": {
        ".write": true,
        ".validate": "!newData.exists() || (newData.hasChild('timestamp') && newData.child('timestamp').isNumber())"
      }
    }
  }
}